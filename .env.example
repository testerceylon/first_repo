# # PayPal Subscription Environment Variables

# # Backend API (.env in apps/api/)
# DATABASE_URL=postgresql://user:password@localhost:5432/bunplate
# BETTER_AUTH_SECRET=your-secret-key-here

# # Google OAuth Configuration
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# # PayPal Configuration
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_PLAN_PRO=P-xxxxxxxxxxxxxxxxxxxxx
# PAYPAL_PLAN_PREMIUM=P-xxxxxxxxxxxxxxxxxxxxx

# # Frontend URL for redirects
# FRONTEND_URL=http://localhost:3000

# # Frontend (.env.local in apps/web/)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# # Client Project CRM (services feature)
# # API side (.env in apps/api/)
# ADMIN_EMAIL=you@yourdomain.com             # receives new service request notifications
# PAYPAL_ME_LINK=https://paypal.me/yourhandle  # used when admin sends payment requests

# # Frontend side (.env.local in apps/web/)
# NEXT_PUBLIC_PAYPAL_ME_LINK=https://paypal.me/yourhandle  # displayed in client PayPal CTA cards
# NEXT_PUBLIC_URL=https://yourdomain.com     # used in email deep-links (dashboard/projects)
