# API Production Environment Variables (Vercel)
# Set in: Vercel → nextjs-multiworker-api → Settings → Environment Variables

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# BETTER AUTH
#
# BETTER_AUTH_URL = the full URL where the API mounts the auth handler.
#   better-auth uses this to build OAuth callback URLs.
#
# ✅ Vercel staging (no custom domain):
BETTER_AUTH_URL=https://nextjs-multiworker-api.vercel.app/api/auth
# ✅ Custom domain: BETTER_AUTH_URL=https://api.ghostcod.com/api/auth
#
# Google OAuth authorized redirect URI must be: {BETTER_AUTH_URL}/callback/google
# ─────────────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-production-secret-key-min-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND ORIGIN
#   CORS allowed origins and PayPal redirect URLs.
#   Must be the web app URL — NOT the API's own URL.
#
# ✅ Vercel staging:
FRONTEND_URL=https://nextjs-multiworker-web.vercel.app
CLIENT_URL=https://nextjs-multiworker-web.vercel.app
# ✅ Custom domain: FRONTEND_URL=https://ghostcod.com
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# COOKIE_DOMAIN (optional — DO NOT set on Vercel *.vercel.app)
#
# Only set this when using a shared custom root domain:
#   web → ghostcod.com   +   API → api.ghostcod.com
#
# The Vercel proxy (/api/[[...path]]) already strips the Domain attribute so
# cookies stay first-party on the web domain. Setting a .vercel.app domain here
# would scope cookies to the wrong domain and break auth.
#
# COOKIE_DOMAIN=.ghostcod.com
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────────────────────────────────────
# PAYPAL
# ─────────────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_PRODUCT_ID=your_paypal_product_id
PAYPAL_PLAN_PRO=your_production_plan_id

# Note: VERCEL_ENV and NODE_ENV are set automatically by Vercel — do not add manually.
